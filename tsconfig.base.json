{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@agentdeck/protocol": ["packages/protocol/src/index.ts"],
      "@agentdeck/shared": ["packages/shared/src/index.ts"],
      "@agentdeck/server": ["packages/server/src/index.ts"],
      "@agentdeck/client": ["packages/client/src/index.ts"]
    },
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "useDefineForClassFields": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
