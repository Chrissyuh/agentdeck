{
  "name": "@agentdeck/client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentdeck/protocol": "*",
    "@agentdeck/shared": "*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.3",
    "react": "^19.0.0",
    "tsup": "^8.3.5"
  }
}
